# Windmill build worker (group default), a systemd template: enable one instance
# per index with `systemctl --user enable --now windmill-worker@0 windmill-worker@1`.
# Mirrors deploy/podman/windmill-worker.container.tmpl, but with no container the
# /nix store, the build area, and the user bus are already host-visible, so the
# bind-mounts drop and only the env contract remains.
#
# WORKER_INDEX (%i) selects this worker's sandbox dir under WORKERS_DIR. The
# build-area paths default under the state dir; point them at a real workbench
# (commonly the repo's workbench/) with `systemctl --user edit` or a
# %E/windmill-nix/windmill-worker.env file. The user bus is reached at %t/bus so
# a build step can drive the host systemd --user.
[Unit]
Description=Windmill worker %i (group default; builds) (nix)
Requires=windmill-db.service
After=windmill-db.service

[Service]
Environment=MODE=worker
Environment=NUM_WORKERS=1
Environment=WORKER_GROUP=default
Environment=WORKER_INDEX=%i
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=%t/bus
Environment=WORKBENCH_DIR=%S/windmill-nix/workbench
Environment=SYSTEM_DIR=%S/windmill-nix/workbench/system
Environment=WORKERS_DIR=%S/windmill-nix/workbench/workers
Environment=VENDOR_DIR=%S/windmill-nix/vendor
Environment=WHITELIST_ENVS=DBUS_SESSION_BUS_ADDRESS,XDG_RUNTIME_DIR,WORKER_INDEX,WORKBENCH_DIR,SYSTEM_DIR,WORKERS_DIR,VENDOR_DIR
EnvironmentFile=%S/windmill-nix/env/database.env
EnvironmentFile=-%E/windmill-nix/windmill-worker.env
ExecStart=%S/windmill-nix/sw/windmill/bin/windmill
Restart=always

[Install]
WantedBy=default.target
