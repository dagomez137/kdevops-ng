# One origin in front of the two backends, matching deploy/podman/Caddyfile.
# The websocket paths go to the windmill-extra LSP gateway; everything else to
# the server. The listen address comes from the unit (WMNIX_CADDY_ADDR), default
# loopback :8000; reach the UI with ssh -L 8000:localhost:8000.
#
# auto_https off and the explicit http:// scheme keep caddy a plain HTTP proxy:
# no TLS automation, no :80 redirect vhost, no local CA installed into the system
# trust store. This is a loopback proxy behind an SSH forward, never a public
# origin, so it terminates no TLS.
{
	auto_https off
	admin off
}
# Match any Host on the port (so localhost and 127.0.0.1 both work over the SSH
# forward), but bind the listener to loopback only, mirroring the podman
# backend's 127.0.0.1:8000 publish.
http://:{$WMNIX_CADDY_PORT:8000} {
	bind 127.0.0.1
	# A named matcher: reverse_proxy takes only one inline matcher, so listing
	# several path tokens would be parsed as upstreams (a round-robin pool),
	# not routes. The websocket paths go to the LSP gateway, the rest to the
	# server.
	@ws path /ws/* /ws_mp/* /ws_debug/*
	reverse_proxy @ws 127.0.0.1:3001
	reverse_proxy 127.0.0.1:8002
}
