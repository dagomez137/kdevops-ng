# One origin in front of the two backends, matching deploy/podman/Caddyfile. The
# websocket paths go to the windmill-extra LSP gateway; everything else to the
# server. install.sh renders the @WMNIX_*@ placeholders from CADDY_TLS:
#
#   off       plain HTTP (loopback behind an SSH forward terminates no TLS).
#   internal  HTTPS with caddy's internal CA, trust store untouched (one-time
#             browser warning; run `caddy trust` to remove it).
#   file      HTTPS with an operator-provided cert and key (org CA, mkcert).
#   acme      HTTPS with a real cert for a public domain.
#
# The Secure flag on Windmill's session cookie follows the server's BASE_URL
# (it sets IS_SECURE from base_url starting with https://), which install.sh
# keeps in lockstep with this scheme, so the two never drift.
{
	auto_https @WMNIX_AUTOHTTPS@
	@WMNIX_SKIPTRUST@
	admin off
}
@WMNIX_SITE@ {
	bind 127.0.0.1
	@WMNIX_TLS@
	@WMNIX_HSTS@
	# A named matcher: reverse_proxy takes only one inline matcher, so listing
	# several path tokens would be parsed as upstreams (a round-robin pool),
	# not routes. The websocket paths go to the LSP gateway, the rest to the
	# server.
	@ws path /ws/* /ws_mp/* /ws_debug/*
	reverse_proxy @ws 127.0.0.1:3001
	reverse_proxy 127.0.0.1:8002
}
