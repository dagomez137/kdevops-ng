# SPDX-License-Identifier: copyleft-next-0.3.1
[Unit]
Description=Windmill reverse proxy (Caddy, localhost only)
Requires=windmill.service windmill-extra.service
After=windmill.service windmill-extra.service
[Container]
ContainerName=windmill-caddy
Image=ghcr.io/windmill-labs/caddy-l4:latest
Network=windmill.network
PublishPort=127.0.0.1:8000:80
Volume=%S/windmill/Caddyfile:/etc/caddy/Caddyfile:ro
[Service]
Restart=always
[Install]
WantedBy=default.target
