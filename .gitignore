# windmill runtime state lives in ~/.local/share/windmill (XDG), never here
# wmill CLI auth lives in ~/.config/windmill, never here
*.token
.env

# The build area (ADR-0008): the relocatable workbench/ holding the System
# workbench, the per-worker sandboxes, the shared runtime caches and the developer
# worktree-groups. Large, regenerated, not source. The vendored projects
# (nixos-flake, qemu-system-units, linux-config-fragments) live in the top-level
# vendor/ (tracked, ADR-0006); everything under the build area is runtime-only.
# workers/ is the pre-migration location, kept ignored through the transition.
/workbench/*
/workers/*

# Generated by `wmill init`; regenerate rather than track.
/AGENTS.cli.md
/tsconfig.json
/tsconfig.wmill.json
/.claude/
/.agents/

# Python bytecode cache from local script checks
__pycache__/

# Sphinx HTML output; rebuilt locally and by Read the Docs, never tracked.
/docs/_build/

# `nix build` GC-root symlinks (e.g. from `nix build .#checks.<system>.lint`).
/result
/result-*
