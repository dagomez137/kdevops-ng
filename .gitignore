# windmill runtime state lives in ~/.local/share/windmill (XDG), never here
# wmill CLI auth lives in ~/.config/windmill, never here
*.token
.env

# Per-worker build sandboxes + shared runtime caches: large, regenerated, not
# source. The vendored projects (nixos-flake, qemu-system-units,
# linux-config-fragments) now live in the top-level vendor/ (tracked, ADR-0006),
# so everything under workers/ is runtime-only.
/workers/*

# Generated by `wmill init`; regenerate rather than track.
/AGENTS.cli.md
/tsconfig.json
/tsconfig.wmill.json
/.claude/
/.agents/

# Python bytecode cache from local script checks
__pycache__/

# Sphinx HTML output; rebuilt locally and by Read the Docs, never tracked.
/docs/_build/
