# windmill runtime state lives in ~/.local/share/windmill (XDG), never here
# wmill CLI auth lives in ~/.config/windmill, never here
*.token
.env

# Per-worker build sandboxes + shared source trees (runtime, large, not source).
# Exception: nixos-flake, qemu-system-units and linux-config-fragments are
# vendored under workers/shared (tracked); everything else under workers/ stays
# runtime-only.
/workers/*
!/workers/shared/
/workers/shared/*
!/workers/shared/nixos-flake/
!/workers/shared/qemu-system-units/
!/workers/shared/linux-config-fragments/

# Generated by `wmill init`; regenerate rather than track.
/AGENTS.cli.md
/tsconfig.json
/tsconfig.wmill.json
/.claude/
/.agents/

# Python bytecode cache from local script checks
__pycache__/
