# Help: NVMe host driver (PCIe)
#
# The local PCIe NVMe block driver and its host-side features:
# multipath (ANA) access to NVMe subsystems, hardware monitoring
# (drive temperature via hwmon), verbose error reporting, and fault
# injection (nvme_should_fail, for blktests error-path tests). Pairs
# with storage/nvme-fabrics.config (NVMe-over-Fabrics transports and
# target) and storage/nvme-tls.config (TCP TLS encryption).
#
# CMB and PMR have no Kconfig symbols: CMB is exposed as peer-to-peer
# DMA memory by the driver (needs PCI_P2PDMA), and the host driver has
# no PMR support. The ZONE_DEVICE / PCI_P2PDMA chain below backs CMB;
# it needs memory hotplug and migration (64-bit, from the base).
#
# Layer builtin/storage/nvme.config to build NVMe in (=y).
# See: drivers/nvme/host/Kconfig
# See: drivers/pci/Kconfig (PCI_P2PDMA)

#
# Host driver and features
#
CONFIG_BLK_DEV_NVME=m
CONFIG_NVME_MULTIPATH=y
CONFIG_NVME_HWMON=y
CONFIG_NVME_VERBOSE_ERRORS=y

#
# Fault injection (nvme_should_fail). There is no NVMe-specific
# symbol: nvme-core's fault_inject.o is gated by the generic debugfs
# fault-injection interface (the configfs variant in
# storage/block-test-devices.config is for null_blk). FAULT_INJECTION
# needs DEBUG_KERNEL, and DEBUG_FS/SYSFS come from the base.
#
CONFIG_FAULT_INJECTION=y
CONFIG_FAULT_INJECTION_DEBUG_FS=y

#
# CMB peer-to-peer DMA (ZONE_DEVICE / PCI_P2PDMA chain)
#
CONFIG_MEMORY_HOTPLUG=y
CONFIG_MEMORY_HOTREMOVE=y
CONFIG_MIGRATION=y
CONFIG_ZONE_DEVICE=y
CONFIG_PCI_P2PDMA=y
