# Help: NVMe over Fabrics (host and target, all transports)
#
# Enables host and target drivers for every NVMe-oF transport: TCP,
# FC, RDMA, and the target-side loopbacks (NVME_TARGET_LOOP and
# NVME_TARGET_FCLOOP). Used by blktests nvme-* test groups.
#
# RDMA deliberately pulls in BOTH software providers because a VM
# guest normally has no HCA: RDMA_RXE (software RoCE over UDP/IP)
# and RDMA_SIW (software iWARP over TCP/IP). Enabling both lets a
# test pick whichever provider it needs without rebuilding.
# INFINIBAND_ADDR_TRANS (RDMA CM) is default y under INFINIBAND but
# is set explicitly because allnoconfig-based merges start every
# bool at =n regardless of Kconfig default. INFINIBAND_VIRT_DMA is
# def_bool !HIGHMEM and lights up automatically on non-HIGHMEM
# configs.
#
# NVME_FABRICS, NVME_AUTH, and NVME_KEYRING are internal tristates
# selected through Kconfig by the transport and auth symbols, so
# they do not appear directly here.
#
# TCP TLS encryption (NVME_TCP_TLS, NVME_TARGET_TCP_TLS) is an opt-in
# add-on with its own TLS/handshake stack; it lives in
# storage/nvme-tls.config. Deliberately omitted: NVME_APPLE (Apple
# SoC, not a QEMU/x86 guest device), NVME_TARGET_PCI_EPF (needs a PCI
# endpoint controller), NVME_TARGET_AUTH_DEBUG (prints DH-HMAC-CHAP
# secrets), and NVME_AUTH_KUNIT_TEST (test module).
# See: drivers/nvme/host/Kconfig
# See: drivers/nvme/target/Kconfig
# See: drivers/nvme/common/Kconfig
# See: drivers/infiniband/Kconfig
# See: drivers/infiniband/sw/rxe/Kconfig
# See: drivers/infiniband/sw/siw/Kconfig
# See: https://github.com/linux-nvme/nvme-cli
# See: https://github.com/linux-blktests/blktests

#
# RDMA stack (inlined for NVME_RDMA and NVME_TARGET_RDMA): core
# InfiniBand, userspace verbs/CM, and both software providers
#
CONFIG_INFINIBAND=m
CONFIG_INFINIBAND_ADDR_TRANS=y
CONFIG_INFINIBAND_USER_ACCESS=m
CONFIG_RDMA_RXE=m
CONFIG_RDMA_SIW=m

#
# Host transports
#
CONFIG_NVME_MULTIPATH=y
CONFIG_NVME_TCP=m
CONFIG_NVME_FC=m
CONFIG_NVME_RDMA=m
CONFIG_NVME_HOST_AUTH=y

#
# Target core and transports
#
CONFIG_NVME_TARGET=m
CONFIG_NVME_TARGET_DEBUGFS=y
CONFIG_NVME_TARGET_PASSTHRU=y
CONFIG_NVME_TARGET_LOOP=m
CONFIG_NVME_TARGET_TCP=m
CONFIG_NVME_TARGET_FC=m
CONFIG_NVME_TARGET_FCLOOP=m
CONFIG_NVME_TARGET_RDMA=m
CONFIG_NVME_TARGET_AUTH=y
