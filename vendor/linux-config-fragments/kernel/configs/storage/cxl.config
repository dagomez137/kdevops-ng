# Help: CXL (Compute Express Link) memory expansion
#
# Full CXL subsystem for testing CXL type-3 devices (memory
# expanders), CXL-attached pmem, CXL PMU (performance monitoring
# unit), CXL MCE routing for machine-check events, CXL PCIe
# driver, and the CXL ACPI port driver. CXL_REGION=y enables host
# region assembly; CXL_SUSPEND wires CXL into the platform suspend
# path; CXL_REGION_INVALIDATION_TEST is an opt-in that injects
# invalidation faults for regression testing.
# CXL_MEM_RAW_COMMANDS=y exposes the /dev/cxl/memN raw mailbox
# interface used by cxl-cli for vendor-specific commands.
#
# PCIe-attached CXL works in QEMU with the cxl-type3 and cxl-rp
# models.
# See: drivers/cxl/Kconfig
# See: https://docs.kernel.org/driver-api/cxl/index.html
# See: https://github.com/pmem/ndctl (cxl-cli)

CONFIG_CXL_BUS=m
CONFIG_CXL_PCI=m
CONFIG_CXL_ACPI=m
CONFIG_CXL_PORT=m
CONFIG_CXL_MEM=m
CONFIG_CXL_PMEM=m
CONFIG_CXL_PMU=m
CONFIG_CXL_MCE=y
CONFIG_CXL_REGION=y
CONFIG_CXL_SUSPEND=y
CONFIG_CXL_MEM_RAW_COMMANDS=y
CONFIG_CXL_REGION_INVALIDATION_TEST=y
