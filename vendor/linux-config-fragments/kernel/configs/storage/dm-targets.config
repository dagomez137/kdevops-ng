# Help: Device mapper targets for storage testing
#
# DM targets exercised by blktests dm-* and fstests scenarios:
# dm-crypt (encrypted volumes), dm-thin-provisioning, dm-cache
# (SSD caching), dm-raid (RAID layered on DM), dm-multipath,
# dm-snapshot, dm-integrity, dm-flakey/dm-delay/dm-dust (fault
# injection), dm-log-writes (fs crash-consistency testing).
#
# CONFIG_MD is a bool umbrella for the entire drivers/md menu
# (both MD software RAID and Device Mapper), so it must be =y for
# any DM target to be reachable.
# See: drivers/md/Kconfig
# See: https://docs.kernel.org/admin-guide/device-mapper/index.html
# See: https://gitlab.com/cryptsetup/cryptsetup

#
# MD umbrella and DM core
#
CONFIG_MD=y
CONFIG_BLK_DEV_DM=m

#
# Encryption and integrity
#
CONFIG_DM_CRYPT=m
CONFIG_DM_INTEGRITY=m

#
# Snapshot, thin provisioning, cache
#
CONFIG_DM_SNAPSHOT=m
CONFIG_DM_THIN_PROVISIONING=m
CONFIG_DM_CACHE=m
CONFIG_DM_CACHE_SMQ=m
CONFIG_DM_WRITECACHE=m
CONFIG_DM_ERA=m
CONFIG_DM_CLONE=m
CONFIG_DM_MIRROR=m

#
# RAID via DM (pulls MD_RAID* modules through select)
#
CONFIG_DM_RAID=m

#
# Multipath and I/O path selectors
#
CONFIG_DM_MULTIPATH=m
CONFIG_DM_MULTIPATH_QL=m
CONFIG_DM_MULTIPATH_ST=m
CONFIG_DM_MULTIPATH_HST=m

#
# Fault injection and testing targets
#
CONFIG_DM_FLAKEY=m
CONFIG_DM_DELAY=m
CONFIG_DM_DUST=m
CONFIG_DM_LOG_WRITES=m
CONFIG_DM_ZERO=m
