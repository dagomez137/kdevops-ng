# Help: KVM host support for nested virtualization
#
# x86_64 KVM hypervisor with Intel VMX and AMD SVM support.
# Enables running VMs inside a QEMU guest (nested virtualization).
# See: https://docs.kernel.org/virt/kvm/index.html
CONFIG_VIRTUALIZATION=y
CONFIG_KVM=m
CONFIG_KVM_INTEL=m
CONFIG_KVM_AMD=m
CONFIG_KVM_IOAPIC=y
CONFIG_KVM_SMM=y
