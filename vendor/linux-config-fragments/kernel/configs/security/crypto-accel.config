# Help: x86 architecture-accelerated cryptography
#
# Modules under arch/x86/crypto that auto-register with the
# crypto API at load time. They provide ISA-accelerated (AES-NI,
# SSSE3, AVX, AVX2, PCLMULQDQ) variants of the generic algorithms
# from security/crypto-algorithms.config and win on throughput
# whenever the host (and pass-through to guest) exposes the
# matching CPU flags.
#
# Scope note (kernel 7.1): the SHA-1/256/512, ChaCha20, Poly1305,
# NHPoly1305, GHASH (CLMUL), BLAKE2s, Curve25519, and 3DES x86
# implementations no longer have standalone CONFIG_*_X86* symbols.
# They were folded into the lib/crypto framework (lib/crypto/x86/),
# which builds the arch-optimized backend automatically alongside
# the generic algorithm; there is nothing to set for them here.
# Only the cipher families that still carry their own arch symbol
# remain below.
#
# On non-x86 arches none of these symbols exist, so the fragment
# is a no-op (merge_config only warns about the unknown symbols).
# On arm/arm64 the equivalent NEON and CE variants are selected
# automatically by arch/arm*/crypto/Kconfig when the matching
# feature is built; no dedicated fragment is needed.
#
# Every symbol is tristate. No builtin/ counterpart is needed;
# users who want these promoted to =y set them ad-hoc.
# See: arch/x86/crypto/Kconfig
# See: lib/crypto/x86/ (library-internal arch backends)
# See: https://docs.kernel.org/crypto/architecture.html

#
# AES
#
CONFIG_CRYPTO_AES_NI_INTEL=m

#
# Camellia / CAST5 / CAST6 / Serpent / Twofish
#
CONFIG_CRYPTO_CAMELLIA_AESNI_AVX_X86_64=m
CONFIG_CRYPTO_CAMELLIA_AESNI_AVX2_X86_64=m
CONFIG_CRYPTO_CAST5_AVX_X86_64=m
CONFIG_CRYPTO_CAST6_AVX_X86_64=m
CONFIG_CRYPTO_SERPENT_SSE2_X86_64=m
CONFIG_CRYPTO_SERPENT_AVX_X86_64=m
CONFIG_CRYPTO_SERPENT_AVX2_X86_64=m
CONFIG_CRYPTO_TWOFISH_X86_64=m
CONFIG_CRYPTO_TWOFISH_X86_64_3WAY=m
CONFIG_CRYPTO_TWOFISH_AVX_X86_64=m

#
# AEGIS128 / Blowfish
#
CONFIG_CRYPTO_AEGIS128_AESNI_SSE2=m
CONFIG_CRYPTO_BLOWFISH_X86_64=m
