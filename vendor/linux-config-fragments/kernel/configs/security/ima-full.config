# Help: Full IMA and EVM policy infrastructure
#
# Self-contained: inlines the base SECURITY/INTEGRITY/IMA stack (the
# same values security/security.config sets) so it composes on the
# base alone. This fragment enables the
# policy-loading interfaces (IMA_WRITE_POLICY, IMA_READ_POLICY),
# modsig (module signature) appraisal, asymmetric-key measurement,
# the trusted and blacklist keyrings, LSM-rule conditions in IMA
# policies, and the EVM attribute-level protection module with
# fsuuid and xattr extensions.
#
# Prerequisites are inlined so the fragment composes standalone:
# - SYSTEM_TRUSTED_KEYRING=y     gates INTEGRITY_TRUSTED_KEYRING,
#                                IMA_BLACKLIST_KEYRING, and
#                                IMA_KEYRINGS_PERMIT_SIGNED_BY_*.
# - SECONDARY_TRUSTED_KEYRING=y  gates
#                                IMA_KEYRINGS_PERMIT_SIGNED_BY_BUILTIN_OR_SECONDARY.
# - SYSTEM_BLACKLIST_KEYRING=y   gates INTEGRITY_PLATFORM_KEYRING.
# - ASYMMETRIC_PUBLIC_KEY_SUBTYPE=y  gates IMA_MEASURE_ASYMMETRIC_KEYS.
# - AUDIT=y and (SELINUX || SMACK || APPARMOR) gate IMA_LSM_RULES.
#   AUDIT is inlined, but an LSM is a major subsystem this fragment
#   does not choose for you. IMA_LSM_RULES is the one symbol here
#   that only lands when an LSM fragment (security/lsm-modules.config)
#   is also on the line; everything else composes on the base alone.
#
# IMA_APPRAISE_MODSIG is compatible with CONFIG_MODULE_SIG=n
# because the modsig appraisal reuses the PKCS7 parser rather
# than the module-signing verification path. It selects
# MODULE_SIG_FORMAT and PKCS7_MESSAGE_PARSER.
#
# All symbols are bool; no builtin/ counterpart is needed.
# See: security/integrity/Kconfig
# See: security/integrity/ima/Kconfig
# See: security/integrity/evm/Kconfig
# See: certs/Kconfig
# See: https://docs.kernel.org/admin-guide/ima_policy.html

#
# Inlined prerequisites
#
# Base SECURITY/INTEGRITY/IMA stack (security/security.config)
CONFIG_SECURITY=y
CONFIG_INTEGRITY=y
CONFIG_INTEGRITY_SIGNATURE=y
CONFIG_INTEGRITY_ASYMMETRIC_KEYS=y
CONFIG_IMA=y
CONFIG_IMA_APPRAISE=y

CONFIG_AUDIT=y
CONFIG_SYSTEM_TRUSTED_KEYRING=y
CONFIG_SECONDARY_TRUSTED_KEYRING=y
CONFIG_SYSTEM_BLACKLIST_KEYRING=y

#
# Integrity keyring infrastructure
#
CONFIG_INTEGRITY_TRUSTED_KEYRING=y
CONFIG_INTEGRITY_PLATFORM_KEYRING=y

#
# IMA policy interfaces
#
CONFIG_IMA_WRITE_POLICY=y
CONFIG_IMA_READ_POLICY=y
CONFIG_IMA_LSM_RULES=y

#
# IMA appraisal extensions
#
CONFIG_IMA_APPRAISE_BOOTPARAM=y
CONFIG_IMA_APPRAISE_MODSIG=y

#
# IMA measurement extensions
#
CONFIG_IMA_MEASURE_ASYMMETRIC_KEYS=y
CONFIG_IMA_QUEUE_EARLY_BOOT_KEYS=y

#
# IMA keyring policy
#
CONFIG_IMA_KEYRINGS_PERMIT_SIGNED_BY_BUILTIN_OR_SECONDARY=y
CONFIG_IMA_BLACKLIST_KEYRING=y

#
# EVM (extended verification module)
#
CONFIG_EVM=y
CONFIG_EVM_ATTR_FSUUID=y
CONFIG_EVM_ADD_XATTRS=y
