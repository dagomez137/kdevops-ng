# Help: Advanced XFS features (quota, realtime, scrub, repair)
#
# Self-contained: inlines fs/xfs.config's XFS_FS so it composes on
# the base alone, with or without fs/xfs.config also on the line.
# Enables features exercised by
# xfstests: quota accounting (XFS_QUOTA), realtime subvolumes
# (XFS_RT), online metadata scrub (XFS_ONLINE_SCRUB), its stats
# sibling, and online repair (XFS_ONLINE_REPAIR). XFS_WARN turns
# ASSERT checks into WARN logs so metadata anomalies surface
# during testing without panicking the kernel.
#
# XFS_DEBUG is a stricter mode that is mutually exclusive with
# XFS_WARN (Kconfig rule "depends on XFS_FS && !XFS_DEBUG") and
# therefore lives in its own fragment, not here.
#
# All symbols are bool and parent on tristate XFS_FS, which
# Kconfig permits with XFS_FS=m. No builtin/ counterpart is
# needed.
# See: fs/xfs/Kconfig
# See: https://docs.kernel.org/filesystems/xfs/index.html

#
# Inlined prerequisite (fs/xfs.config)
#
CONFIG_XFS_FS=m
CONFIG_XFS_POSIX_ACL=y

CONFIG_XFS_QUOTA=y
CONFIG_XFS_RT=y
CONFIG_XFS_ONLINE_SCRUB=y
CONFIG_XFS_ONLINE_SCRUB_STATS=y
CONFIG_XFS_ONLINE_REPAIR=y
CONFIG_XFS_WARN=y
