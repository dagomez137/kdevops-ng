# Help: ISO9660 and UDF filesystems (CD/DVD media, seed ISOs)
#
# ISO9660_FS=m for the ISO9660 (CDFS) primary volume descriptor,
# JOLIET=y for the Joliet extension (Windows long filenames on
# CDs), ZISOFS=y for compressed ISO9660, UDF_FS=m for the
# Universal Disk Format used by DVDs, Blu-rays, and some
# packet-written optical media.
#
# Most relevant in VM guests as the filesystem for cloud-init
# seed ISOs (NoCloud datasource) that are presented as virtio-blk
# or IDE/ATAPI drives.
# See: fs/isofs/Kconfig
# See: fs/udf/Kconfig

CONFIG_ISO9660_FS=m
CONFIG_JOLIET=y
CONFIG_ZISOFS=y
CONFIG_UDF_FS=m
