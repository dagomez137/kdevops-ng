# Help: x86 platform feature knobs beyond arch/x86_64.config
#
# The MCE family (Machine Check Exception) exposes hardware error
# reporting for both Intel and AMD CPUs. X86_X2APIC enables the
# extended APIC mode used on >256-thread systems. X86_PAT enables
# the Page Attribute Table, required for correct write-combining
# and uncached mappings. X86_UMIP traps userspace SGDT/SIDT/SLDT/
# SMSW/STR to shut down fingerprinting. X86_IOPL_IOPERM restores
# the per-task I/O permission bitmap (dropped by default in
# 5.5+). The remaining symbols are auto-selected by x86 arch
# paths and are listed explicitly so allnoconfig-based merges do
# not lose them.
# See: arch/x86/Kconfig
# See: https://docs.kernel.org/x86/index.html
# See: https://docs.kernel.org/admin-guide/ras.html

#
# MTRR is def_bool y with an EXPERT prompt; allnoconfig-based
# merges leave it =n, and X86_PAT depends on MTRR. Set it
# explicitly to pick up PAT.
#
CONFIG_MTRR=y
CONFIG_X86_MCE=y
CONFIG_X86_MCE_INTEL=y
CONFIG_X86_MCE_AMD=y
CONFIG_X86_MCE_THRESHOLD=y
CONFIG_X86_X2APIC=y
CONFIG_X86_PAT=y
CONFIG_X86_UMIP=y
CONFIG_X86_IOPL_IOPERM=y
CONFIG_X86_BUS_LOCK_DETECT=y
CONFIG_X86_PM_TIMER=y
CONFIG_X86_MPPARSE=y
CONFIG_X86_INTEL_LPSS=y
CONFIG_X86_INTEL_MEMORY_PROTECTION_KEYS=y
CONFIG_X86_AMD_PLATFORM_DEVICE=y
CONFIG_X86_REROUTE_FOR_BROKEN_BOOT_IRQS=y
CONFIG_X86_SUPPORTS_MEMORY_FAILURE=y
CONFIG_X86_VSYSCALL_EMULATION=y
CONFIG_X86_16BIT=y
CONFIG_X86_64_SMP=y
CONFIG_X86_ESPFIX64=y
