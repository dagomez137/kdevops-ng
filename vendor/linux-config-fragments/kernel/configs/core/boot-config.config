# Help: Boot configuration and 32-bit userspace compatibility
#
# BOOT_CONFIG adds the bootconfig command-line extension mechanism
# (extra kernel parameters appended to the initramfs, consumed by
# init_boot_config()). BOOT_PRINTK_DELAY adds a delay after each
# early printk for debugging boot hangs.
#
# CHECKPOINT_RESTORE exposes the syscalls criu uses to freeze and
# restore processes. CPUSETS lets administrators partition CPUs
# and memory nodes among task groups. BSD_PROCESS_ACCT family
# writes per-process accounting records to a user-specified file.
# BUG_ON_DATA_CORRUPTION promotes list-corruption sanity checks
# from warnings to kernel panics. CONNECTOR enables the netlink
# connector used by the process events subsystem (proc_events).
# CONSOLE_TRANSLATIONS allows VT keymaps to translate bytes.
# CORE_DUMP_DEFAULT_ELF_HEADERS puts ELF headers in core dumps.
# CACHESTAT_SYSCALL exposes cachestat(2), the page-cache residency
# syscall.
#
# The COMPAT* cluster enables 32-bit userspace on 64-bit kernels:
# COMPAT and COMPAT_32 are the top-level switches,
# COMPAT_BINFMT_ELF handles 32-bit ELF binaries, COMPAT_32BIT_TIME
# keeps 32-bit time_t syscalls live, COMPAT_FOR_U64_ALIGNMENT
# preserves ABI alignment, COMPAT_OLD_SIGACTION and IA32_EMULATION
# cover the legacy 32-bit entry path on x86_64.
# See: init/Kconfig
# See: kernel/Kconfig.preempt
# See: https://docs.kernel.org/admin-guide/bootconfig.html
# See: https://docs.kernel.org/admin-guide/cgroup-v1/cpusets.html
# See: https://criu.org/ (checkpoint / restore in user space)

#
# Boot-time configuration
#
CONFIG_BOOT_CONFIG=y
CONFIG_BOOT_PRINTK_DELAY=y

#
# Process and core features
#
CONFIG_CHECKPOINT_RESTORE=y
CONFIG_CPUSETS=y
CONFIG_BSD_PROCESS_ACCT=y
CONFIG_BSD_PROCESS_ACCT_V3=y
CONFIG_BUG_ON_DATA_CORRUPTION=y
CONFIG_CONNECTOR=y
CONFIG_CONSOLE_TRANSLATIONS=y
CONFIG_CORE_DUMP_DEFAULT_ELF_HEADERS=y
CONFIG_CACHESTAT_SYSCALL=y

#
# 32-bit userspace compatibility on x86_64
#
CONFIG_COMPAT=y
CONFIG_COMPAT_32=y
CONFIG_COMPAT_BINFMT_ELF=y
CONFIG_COMPAT_32BIT_TIME=y
CONFIG_COMPAT_FOR_U64_ALIGNMENT=y
CONFIG_COMPAT_OLD_SIGACTION=y
CONFIG_IA32_EMULATION=y
