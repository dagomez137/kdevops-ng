# Help: systemd mandatory and strongly recommended kernel configs
#
# Depends on: core.config (NET, PROC_FS, SYSFS, SHMEM, DEVTMPFS)
# See: https://github.com/systemd/systemd/blob/main/README

#
# General setup
#
CONFIG_AUDIT=n
CONFIG_NAMESPACES=y
CONFIG_USER_NS=y
CONFIG_NET_NS=y
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_FHANDLE=y
CONFIG_INOTIFY_USER=y
CONFIG_KCMP=y
CONFIG_MEMCG=y
CONFIG_PSI=y
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

#
# Cgroups
#
CONFIG_CGROUPS=y
CONFIG_CGROUP_SCHED=y
CONFIG_FAIR_GROUP_SCHED=y
CONFIG_CFS_BANDWIDTH=y
CONFIG_RT_GROUP_SCHED=n

#
# File systems
#
CONFIG_TMPFS=y
CONFIG_TMPFS_XATTR=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_AUTOFS_FS=m

#
# SCSI. BLK_DEV_BSG is bool, depends on SCSI.
#
CONFIG_SCSI=y
CONFIG_BLK_DEV_BSG=y
CONFIG_SCSI_LOWLEVEL=y
CONFIG_SCSI_VIRTIO=m

#
# Device firmware
#
CONFIG_DMI=y
CONFIG_DMIID=y
CONFIG_FW_LOADER_USER_HELPER=n

#
# Networking
#
# IPV6 was tristate through 7.0; commit 309b905deee5
# ("ipv6: convert CONFIG_IPV6 to built-in only and clean up
# Kconfigs") changed it to bool in 7.1, so =m is silently
# demoted to "is not set" on newer kernels. =y is valid on
# every version that has the symbol.
CONFIG_IPV6=y
