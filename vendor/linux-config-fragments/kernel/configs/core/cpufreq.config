# Help: CPU frequency and idle management
#
# CPU_FREQ framework with the schedutil default governor (ondemand
# and performance also built in), CPU_FREQ_STAT for sysfs
# counters, CPU_IDLE framework with the menu, ladder, and haltpoll
# governors, and INTEL_IDLE (mwait-based idle driver for Intel
# CPUs). amd-pstate and intel-pstate are not set; the generic
# acpi-cpufreq driver plus schedutil cover most VM-guest
# scenarios.
#
# Every symbol is bool. No builtin/ counterpart needed.
# See: drivers/cpufreq/Kconfig
# See: drivers/cpuidle/Kconfig
# See: drivers/idle/Kconfig
# See: https://docs.kernel.org/admin-guide/pm/cpufreq.html
# See: https://docs.kernel.org/admin-guide/pm/cpuidle.html

#
# Frequency scaling
#
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_STAT=y
CONFIG_CPU_FREQ_GOV_ATTR_SET=y
CONFIG_CPU_FREQ_GOV_COMMON=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_ONDEMAND=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y

#
# Idle management
#
CONFIG_CPU_IDLE=y
CONFIG_CPU_IDLE_GOV_LADDER=y
CONFIG_CPU_IDLE_GOV_MENU=y
CONFIG_CPU_IDLE_GOV_HALTPOLL=y
CONFIG_INTEL_IDLE=y
