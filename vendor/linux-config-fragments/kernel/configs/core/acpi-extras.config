# Help: ACPI platform subsystem (x86/arm64 firmware glue)
#
# APEI (error injection/reporting), HMAT (heterogeneous memory
# topology), CPU/memory/IOAPIC hotplug, NUMA, CPPC (ACPI-driven
# cpufreq), DOCK/CONTAINER hotplug, table upgrade/library,
# sleep/S3, processor idle and C-state drivers, NFIT (NVDIMM
# firmware interface), BGRT, extended error log, HED, PRMT, PCC,
# SPCR, and ACPI revision override.
#
# Prerequisites inlined:
# - NUMA + X86_64_ACPI_NUMA gate ACPI_NUMA on x86 (x86 selects
#   ACPI_NUMA through X86_64_ACPI_NUMA; arm64 uses
#   "def_bool NUMA && !X86").
# - MEMORY_HOTPLUG gates ACPI_HOTPLUG_MEMORY.
# - SUSPEND + HIBERNATION gate ACPI_SLEEP.
# - PCIEPORTBUS + PCIEAER gate ACPI_APEI_PCIEAER.
# - I2C gates ACPI_I2C_OPREGION.
#
# ACPI_EXTLOG additionally needs EDAC + X86_MCE + X86_LOCAL_APIC;
# layer an RAS/EDAC fragment to activate it.
#
# Every symbol is bool except ACPI_NFIT and ACPI_BUTTON (=m).
# No builtin/ counterpart needed.
# See: drivers/acpi/Kconfig
# See: arch/x86/Kconfig (X86_64_ACPI_NUMA)
# See: https://docs.kernel.org/admin-guide/acpi/index.html

#
# Inlined prerequisites
#
CONFIG_NUMA=y
CONFIG_X86_64_ACPI_NUMA=y
CONFIG_MEMORY_HOTPLUG=y
CONFIG_SUSPEND=y
CONFIG_HIBERNATION=y
CONFIG_PCIEPORTBUS=y
CONFIG_PCIEAER=y
CONFIG_I2C=y

CONFIG_ACPI_APEI=y
CONFIG_ACPI_APEI_GHES=y
CONFIG_ACPI_APEI_MEMORY_FAILURE=y
CONFIG_ACPI_APEI_PCIEAER=y
CONFIG_ACPI_BGRT=y
CONFIG_ACPI_BUTTON=m
CONFIG_ACPI_CONTAINER=y
CONFIG_ACPI_CPPC_LIB=y
CONFIG_ACPI_DOCK=y
CONFIG_ACPI_EXTLOG=y
CONFIG_ACPI_HED=y
CONFIG_ACPI_HMAT=y
CONFIG_ACPI_HOTPLUG_CPU=y
CONFIG_ACPI_HOTPLUG_IOAPIC=y
CONFIG_ACPI_HOTPLUG_MEMORY=y
CONFIG_ACPI_I2C_OPREGION=y
CONFIG_ACPI_NFIT=m
CONFIG_ACPI_NUMA=y
CONFIG_ACPI_PCC=y
CONFIG_ACPI_PRMT=y
CONFIG_ACPI_PROCESSOR=y
CONFIG_ACPI_PROCESSOR_CSTATE=y
CONFIG_ACPI_PROCESSOR_IDLE=y
CONFIG_ACPI_REV_OVERRIDE_POSSIBLE=y
CONFIG_ACPI_SLEEP=y
CONFIG_ACPI_SPCR_TABLE=y
CONFIG_ACPI_TABLE_LIB=y
CONFIG_ACPI_TABLE_UPGRADE=y
