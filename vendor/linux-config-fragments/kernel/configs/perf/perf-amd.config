# Help: AMD performance monitoring support
#
# Power reporting, uncore events, and branch sampling for AMD
# processors. Depends on PERF_EVENTS (from core.config or ebpf.config)
# and CPU_SUP_AMD (default y on x86_64).
#
# QEMU requires -cpu host,pmu=on to expose the PMU to the guest.
# Basic perf (cycles, instructions, cache) works. IBS-based features
# (perf mem, perf c2c) do not work in guests: QEMU exposes the IBS
# CPUID bit but does not virtualize IBS MSRs.
# See: https://docs.kernel.org/admin-guide/perf/amd-ibs.html
CONFIG_PERF_EVENTS_AMD_POWER=m
CONFIG_PERF_EVENTS_AMD_UNCORE=m
CONFIG_PERF_EVENTS_AMD_BRS=y
