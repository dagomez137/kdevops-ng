# Help: Rust kernel sample modules
#
# Self-contained: inlines rust.config's RUST (and the RANDSTRUCT_NONE
# it requires) so it composes on the base alone. modules.config is
# part of the base.

#
# Inlined prerequisites (rust.config)
#
CONFIG_RANDSTRUCT_NONE=y
CONFIG_RUST=y

CONFIG_SAMPLES=y
CONFIG_SAMPLES_RUST=y
CONFIG_SAMPLE_RUST_MINIMAL=m
