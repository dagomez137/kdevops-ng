# Help: nftables framework and family modules
#
# nftables is the modern netfilter packet classification framework
# and the current replacement for iptables. Enables the core
# framework, the main address families (IPv4, IPv6, inet, arp,
# netdev, bridge), every common expression/statement module that
# nft rulesets reference (CT, NAT, MASQ, REDIR, REJECT, LOG,
# LIMIT, QUEUE, QUOTA, HASH, FIB, SOCKET, OSF, TPROXY, SYNPROXY,
# XFRM, TUNNEL, NUMGEN, CONNLIMIT, FLOW_OFFLOAD), NFT_COMPAT for
# running iptables extensions under nftables, and the NF_FLOW_TABLE
# flow-offload infrastructure.
#
# nftables can coexist with net/netfilter-nat.config; many
# deployments run iptables-nft on top of nftables for tooling
# compatibility. Skip net/netfilter-nat.config if you only want
# the nft path.
# See: net/netfilter/Kconfig
# See: net/ipv4/netfilter/Kconfig
# See: net/ipv6/netfilter/Kconfig
# See: net/bridge/netfilter/Kconfig
# See: https://wiki.nftables.org/

#
# Inlined prerequisites
#
CONFIG_NF_CONNTRACK=m
CONFIG_XFRM_USER=m
CONFIG_BRIDGE=m
CONFIG_NF_REJECT_IPV4=m
CONFIG_NF_REJECT_IPV6=m

#
# nftables core and families (NETFILTER_INGRESS gates the flow
# table below; allnoconfig-based merges start it at =n even though
# its Kconfig default is y, so set it explicitly)
#
CONFIG_NETFILTER_INGRESS=y
CONFIG_NF_TABLES=m
CONFIG_NF_TABLES_INET=y
CONFIG_NF_TABLES_NETDEV=y
CONFIG_NF_TABLES_IPV4=y
CONFIG_NF_TABLES_IPV6=y
CONFIG_NF_TABLES_ARP=y
CONFIG_NF_TABLES_BRIDGE=m

#
# nftables expression and statement modules
#
CONFIG_NFT_NUMGEN=m
CONFIG_NFT_CT=m
CONFIG_NFT_FLOW_OFFLOAD=m
CONFIG_NFT_CONNLIMIT=m
CONFIG_NFT_LOG=m
CONFIG_NFT_LIMIT=m
CONFIG_NFT_MASQ=m
CONFIG_NFT_REDIR=m
CONFIG_NFT_NAT=m
CONFIG_NFT_TUNNEL=m
CONFIG_NFT_QUEUE=m
CONFIG_NFT_QUOTA=m
CONFIG_NFT_REJECT=m
CONFIG_NFT_REJECT_INET=m
CONFIG_NFT_REJECT_NETDEV=m
CONFIG_NFT_COMPAT=m
CONFIG_NFT_HASH=m
CONFIG_NFT_FIB=m
CONFIG_NFT_FIB_INET=m
CONFIG_NFT_FIB_IPV4=m
CONFIG_NFT_FIB_IPV6=m
CONFIG_NFT_FIB_NETDEV=m
CONFIG_NFT_XFRM=m
CONFIG_NFT_SOCKET=m
CONFIG_NFT_OSF=m
CONFIG_NFT_TPROXY=m
CONFIG_NFT_SYNPROXY=m
CONFIG_NFT_DUP_IPV4=m
CONFIG_NFT_DUP_IPV6=m
CONFIG_NFT_DUP_NETDEV=m
CONFIG_NFT_FWD_NETDEV=m
CONFIG_NFT_BRIDGE_REJECT=m

#
# Flow offload infrastructure
#
CONFIG_NF_FLOW_TABLE=m
