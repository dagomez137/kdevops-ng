# Help: Moby (Docker) container support
#
# Kernel configs recommended by Docker's check-config.sh. Tristates
# default to =m; layer builtin/net/moby.config to build them in.
# NETFILTER_ADVANCED is inlined because BRIDGE_NETFILTER depends on it.
# See: https://github.com/moby/moby/blob/master/contrib/check-config.sh
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_BRIDGE=m
CONFIG_BRIDGE_NETFILTER=m
CONFIG_CGROUP_CPUACCT=y
CONFIG_IP_VS=m
CONFIG_NF_CONNTRACK=m
CONFIG_OVERLAY_FS=m
CONFIG_NF_TABLES=m
