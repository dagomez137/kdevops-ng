# Help: Heavy-weight debug infrastructure
#
# Layered on top of the always-on bits in core/core.config
# (DEBUG_KERNEL, DEBUG_FS, MAGIC_SYSRQ, DEBUG_MISC, PRINTK_TIME).
# This fragment enables the more invasive debug facilities:
# virtual-memory runtime checks (DEBUG_VM and DEBUG_VM_PGFLAGS,
# plus the IRQ-off tracker DEBUG_VM_IRQSOFF), kernel-memory leak
# detector (DEBUG_KMEMLEAK), preemption tracking
# (DEBUG_PREEMPT), list-corruption checks (DEBUG_LIST),
# memory-init debug (DEBUG_MEMORY_INIT), verbose BUG() output
# (DEBUG_BUGVERBOSE), page poisoning, hung-task detection and the
# soft/hard lockup detectors with the hrtimer counter source.
#
# DEBUG_INFO_BTF and DEBUG_INFO_BTF_MODULES build BTF type info
# into the kernel and modules so BPF programs can attach by type
# across kernel versions. DEBUG_KMEMLEAK_MEM_POOL_SIZE raises the
# pre-allocated object pool to 16000 entries so the early-boot
# allocator has headroom.
#
# Every symbol is bool. No builtin/ counterpart needed.
# See: lib/Kconfig.debug
# See: mm/Kconfig.debug
# See: https://docs.kernel.org/dev-tools/index.html

#
# Virtual memory debug
#
CONFIG_DEBUG_VM=y
CONFIG_DEBUG_VM_PGFLAGS=y
CONFIG_DEBUG_VM_IRQSOFF=y
CONFIG_DEBUG_MEMORY_INIT=y
CONFIG_PAGE_POISONING=y

#
# Memory leak detection
#
CONFIG_DEBUG_KMEMLEAK=y
CONFIG_DEBUG_KMEMLEAK_MEM_POOL_SIZE=16000

#
# BUG() / list / preempt
#
CONFIG_DEBUG_BUGVERBOSE=y
CONFIG_DEBUG_LIST=y
CONFIG_DEBUG_PREEMPT=y

#
# Hang / lockup detection
#
CONFIG_DETECT_HUNG_TASK=y
CONFIG_DETECT_HUNG_TASK_BLOCKER=y
CONFIG_LOCKUP_DETECTOR=y
CONFIG_SOFTLOCKUP_DETECTOR=y
CONFIG_HARDLOCKUP_DETECTOR=y
CONFIG_HARDLOCKUP_DETECTOR_PERF=y
CONFIG_HARDLOCKUP_CHECK_TIMESTAMP=y
CONFIG_HARDLOCKUP_DETECTOR_COUNTS_HRTIMER=y

#
# BTF type information (BPF CO-RE)
#
# DEBUG_INFO_BTF requires DEBUG_INFO=y and BPF_SYSCALL=y, plus a
# pahole build tool at version 1.16 or newer. Both prerequisites are
# inlined here so BTF lands on the base alone; they overlap with
# debug/gdb.config and security/ebpf.config (same values, merge
# dedups). The pahole version is a host-toolchain requirement the
# fragment cannot express.
#
CONFIG_DEBUG_INFO=y
CONFIG_DEBUG_INFO_DWARF_TOOLCHAIN_DEFAULT=y
CONFIG_DEBUG_INFO_REDUCED=n
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_DEBUG_INFO_BTF=y
CONFIG_DEBUG_INFO_BTF_MODULES=y
