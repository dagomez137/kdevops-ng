# Help: Detect tasks stuck in uninterruptible sleep and dump their stack
#
# DETECT_HUNG_TASK watches for a task blocked in the uninterruptible
# (D) state for longer than DEFAULT_HUNG_TASK_TIMEOUT seconds and
# prints its backtrace to the console, turning a silent stall (a
# wedged boot, a stuck syscall) into a diagnosable trace.
# DETECT_HUNG_TASK_BLOCKER additionally names the task holding the
# lock the victim waits on. Nothing panics: BOOTPARAM_HUNG_TASK_PANIC
# is left off so the guest keeps running and MAGIC_SYSRQ stays usable;
# pass hung_task_panic=1 on the kernel command line to crash on the
# first hang instead.
#
# Relies on DEBUG_KERNEL from core/core.config, as debug-heavy.config
# does. Every symbol is bool or int. No builtin/ counterpart needed.
# See: lib/Kconfig.debug
# See: https://docs.kernel.org/admin-guide/sysctl/kernel.html
CONFIG_DETECT_HUNG_TASK=y
CONFIG_DETECT_HUNG_TASK_BLOCKER=y
CONFIG_DEFAULT_HUNG_TASK_TIMEOUT=120
