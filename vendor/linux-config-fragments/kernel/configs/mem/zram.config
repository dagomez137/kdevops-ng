# Help: Compressed RAM swap (ZRAM) and transparent compressed cache (ZSWAP)
#
# ZRAM block device (/dev/zramN) providing compressed virtual
# swap, ZSWAP transparent in-kernel compressed cache for swap
# pages, ZSMALLOC backing allocator, ZPOOL API.
#
# Compressor defaults:
# - ZRAM_DEF_COMP="lzo-rle" (kernel's LZO-RLE variant)
# - ZSWAP_COMPRESSOR_DEFAULT="lzo" with ZSMALLOC pool
#
# ZRAM_BACKEND_LZO and ZRAM_BACKEND_FORCE_LZO lock the ZRAM
# backend to LZO for size and speed. ZRAM_MULTI_COMP allows a
# secondary recompression pass when the primary is cheap and the
# block is hot.
#
# Prerequisites are inlined per the self-containment rule:
# - SWAP=y   gates ZSWAP. SWAP has default y but allnoconfig-based
#            merges start it at =n, so set it explicitly.
# See: mm/Kconfig
# See: drivers/block/zram/Kconfig
# See: https://docs.kernel.org/admin-guide/blockdev/zram.html
# See: https://docs.kernel.org/admin-guide/mm/zswap.html

#
# Inlined prerequisite
#
CONFIG_SWAP=y

#
# Backing allocator and pool API
#
CONFIG_ZPOOL=y
CONFIG_ZSMALLOC=y
CONFIG_ZSMALLOC_CHAIN_SIZE=8

#
# ZSWAP: transparent compressed cache for swap pages
#
CONFIG_ZSWAP=y
CONFIG_ZSWAP_COMPRESSOR_DEFAULT_LZO=y
CONFIG_ZSWAP_COMPRESSOR_DEFAULT="lzo"
CONFIG_ZSWAP_ZPOOL_DEFAULT_ZSMALLOC=y
CONFIG_ZSWAP_ZPOOL_DEFAULT="zsmalloc"

#
# ZRAM: compressed RAM block device
#
CONFIG_ZRAM=m
CONFIG_ZRAM_BACKEND_LZO=y
CONFIG_ZRAM_BACKEND_FORCE_LZO=y
CONFIG_ZRAM_DEF_COMP_LZORLE=y
CONFIG_ZRAM_DEF_COMP="lzo-rle"
CONFIG_ZRAM_MULTI_COMP=y
