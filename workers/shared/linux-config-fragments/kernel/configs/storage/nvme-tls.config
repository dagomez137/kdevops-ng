# Help: NVMe-over-TCP TLS encryption (host and target)
#
# TLS 1.3 encryption for the NVMe/TCP transport, on both the host
# (NVME_TCP_TLS) and the target (NVME_TARGET_TCP_TLS) side. Split out
# from storage/nvme-fabrics.config because it is opt-in and drags in
# the kernel TLS and netlink-handshake stack (TLS, NET_HANDSHAKE) plus
# a keyring; plaintext NVMe/TCP does not need any of it.
#
# Self-contained: inlines the NVMe/TCP host and target transports the
# TLS bools attach to, so it composes on the base alone. It also
# composes with nvme-fabrics.config (same values, the merge dedups).
# The TLS handshake itself is driven by a userspace daemon
# (ktls-utils); the kernel side is what these symbols enable.
#
# See: drivers/nvme/host/Kconfig (NVME_TCP_TLS)
# See: drivers/nvme/target/Kconfig (NVME_TARGET_TCP_TLS)
# See: https://github.com/oracle/ktls-utils

#
# Inlined NVMe/TCP transports (host + target)
#
CONFIG_NVME_TCP=m
CONFIG_NVME_TARGET=m
CONFIG_NVME_TARGET_TCP=m

#
# TLS encryption (selects TLS, NET_HANDSHAKE, KEYS)
#
CONFIG_NVME_TCP_TLS=y
CONFIG_NVME_TARGET_TCP_TLS=y
