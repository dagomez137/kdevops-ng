# Help: Additional block device drivers (SCSI disk, NBD, DRBD, bcache)
#
# Real and specialized block device drivers, beyond the synthetic
# test set (storage/block-test-devices.config) and NVMe
# (storage/nvme.config): SCSI disk and CD-ROM (BLK_DEV_SD/SR, on the
# SCSI core the base provides via core/systemd.config), the network
# block device (NBD), DRBD replicated storage, and the bcache SSD
# cache.
#
# Prerequisites inlined per the self-containment rule:
# - MD=y   is the drivers/md umbrella that sources bcache/Kconfig;
#          without it BCACHE is invisible. Also set by
#          storage/md-raid.config and storage/dm-targets.config.
#
# Every symbol is tristate, loaded on demand. No builtin/ counterpart
# is shipped; set an ad-hoc =y override if you need one built in.
# See: drivers/scsi/Kconfig
# See: drivers/block/Kconfig
# See: drivers/md/bcache/Kconfig
# See: drivers/block/drbd/Kconfig

#
# Inlined prerequisite
#
CONFIG_MD=y

#
# SCSI disk and CD-ROM
#
CONFIG_BLK_DEV_SD=m
CONFIG_BLK_DEV_SR=m

#
# Network block device and DRBD
#
CONFIG_BLK_DEV_NBD=m
CONFIG_BLK_DEV_DRBD=m

#
# bcache (SSD cache)
#
CONFIG_BCACHE=m
