# Help: Synthetic block devices for testing (loop, ram, null_blk)
#
# The non-hardware block devices a test VM uses with blktests and
# fstests: the loopback driver (back a block device with a file),
# the RAM disk, and null_blk (a no-op block device for block-layer
# benchmarking and fault-injection testing). These travel together;
# block testing wants the whole set.
#
# Tuning: loop with a starting minor count of 8, RAM disk count 16
# and size 4096 KiB.
#
# Prerequisites inlined per the self-containment rule:
# - FAULT_INJECTION=y + FAULT_INJECTION_CONFIGFS=y gate
#   BLK_DEV_NULL_BLK_FAULT_INJECTION (FAULT_INJECTION needs
#   DEBUG_KERNEL, which the base provides). null_blk selects
#   CONFIGFS_FS, which the base provides at =m.
#
# Layer builtin/storage/block-test-devices.config to build these in
# (=y) for a no-modprobe boot.
# See: drivers/block/Kconfig
# See: drivers/block/null_blk/Kconfig

#
# Loopback and RAM disk
#
CONFIG_BLK_DEV_LOOP=m
CONFIG_BLK_DEV_LOOP_MIN_COUNT=8
CONFIG_BLK_DEV_RAM=m
CONFIG_BLK_DEV_RAM_COUNT=16
CONFIG_BLK_DEV_RAM_SIZE=4096

#
# null_blk with fault injection
#
CONFIG_FAULT_INJECTION=y
CONFIG_FAULT_INJECTION_CONFIGFS=y
CONFIG_BLK_DEV_NULL_BLK=m
CONFIG_BLK_DEV_NULL_BLK_FAULT_INJECTION=y

# Block-IO fault injection (fstests IO-error paths)
CONFIG_FAIL_MAKE_REQUEST=y
