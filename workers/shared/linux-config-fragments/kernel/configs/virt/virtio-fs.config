# Help: virtio-fs filesystem sharing
#
# virtiofs DAX, FUSE transport, and memory management dependencies.
# See: https://virtio-fs.gitlab.io/howto-qemu.html

#
# DAX and memory management
#
CONFIG_DAX=y
CONFIG_FS_DAX=y
CONFIG_MEMORY_HOTPLUG=y
CONFIG_MEMORY_HOTREMOVE=y
CONFIG_MIGRATION=y
CONFIG_ZONE_DEVICE=y

#
# FUSE
#
CONFIG_FUSE_FS=m
CONFIG_FUSE_DAX=y
CONFIG_FUSE_IO_URING=y
CONFIG_FUSE_PASSTHROUGH=y

#
# Virtio
#
# VIRTIO_FS selects VIRTIO, which becomes =m via the tristate select
# (VIRTIO_PCI=m in core.config already makes VIRTIO=m).
CONFIG_VIRTIO_FS=m
