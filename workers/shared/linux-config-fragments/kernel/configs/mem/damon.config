# Help: DAMON data access monitoring framework
#
# Memory access pattern monitoring, proactive reclamation, and
# LRU-lists sorting based on access frequency.
# See: https://docs.kernel.org/mm/damon/index.html
CONFIG_DAMON=y
CONFIG_DAMON_VADDR=y
CONFIG_DAMON_PADDR=y
CONFIG_DAMON_SYSFS=y
CONFIG_DAMON_RECLAIM=y
CONFIG_DAMON_LRU_SORT=y
CONFIG_DAMON_STAT=y
CONFIG_DAMON_STAT_ENABLED_DEFAULT=y
