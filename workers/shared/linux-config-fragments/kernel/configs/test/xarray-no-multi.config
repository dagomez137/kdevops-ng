# Help: XArray unit test without multi-index
#
# RUNTIME_TESTING_MENU gates TEST_XARRAY. XARRAY_MULTI requires
# TRANSPARENT_HUGEPAGE or PREEMPT_RT, so both are disabled.
CONFIG_TEST_XARRAY=m
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_DEBUG_VM_PGFLAGS=y
CONFIG_DEBUG_VM=y
CONFIG_RUNTIME_TESTING_MENU=y
CONFIG_XARRAY_MULTI=n
CONFIG_TRANSPARENT_HUGEPAGE=n
CONFIG_PREEMPT_RT=n
