# Help: In-kernel self-test modules
#
# The TEST_* modules that lib/Kconfig.debug exposes for subsystem
# stress and regression testing. Built as =m and loaded on demand
# by test harnesses (kselftests, blktests, fstests).
#
# TEST_KALLSYMS_A/B/C/D + TEST_KALLSYMS_LARGE exercise the kallsyms
# resolver at scale (NUMSYMS=100, SCALE_FACTOR=8). TEST_KMOD,
# TEST_LKM, and TEST_RUNTIME_MODULE stress-test the module loader.
# TEST_MAPLE_TREE and TEST_XARRAY test the XArray / Maple Tree
# data structures (TEST_XARRAY also in test/xarray.config).
# TEST_SYSCTL, TEST_FIRMWARE cover the sysctl and firmware loader
# paths.
#
# Prerequisites inlined per the self-containment rule:
# - RUNTIME_TESTING_MENU=y gates the whole TEST_* menu in
#   lib/Kconfig.debug. Also set by test/xarray.config.
#
# Every symbol is tristate. Loaded on demand by the test harness;
# no builtin/ counterpart needed.
# See: lib/Kconfig.debug
# See: tools/testing/selftests/

CONFIG_RUNTIME_TESTING_MENU=y

CONFIG_TEST_FIRMWARE=m
CONFIG_TEST_KALLSYMS=m
CONFIG_TEST_KALLSYMS_A=m
CONFIG_TEST_KALLSYMS_B=m
CONFIG_TEST_KALLSYMS_C=m
CONFIG_TEST_KALLSYMS_D=m
CONFIG_TEST_KALLSYMS_LARGE=y
CONFIG_TEST_KALLSYMS_NUMSYMS=100
CONFIG_TEST_KALLSYMS_SCALE_FACTOR=8
CONFIG_TEST_KMOD=m
CONFIG_TEST_LKM=m
CONFIG_TEST_MAPLE_TREE=m
CONFIG_TEST_RUNTIME=y
CONFIG_TEST_RUNTIME_MODULE=y
CONFIG_TEST_SYSCTL=m
CONFIG_TEST_XARRAY=m
