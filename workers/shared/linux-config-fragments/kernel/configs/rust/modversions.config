# Help: Module versioning support
#
# Enables MODVERSIONS for ABI compatibility checking between modules
# and the kernel. GENKSYMS (legacy, from source) is the default.
# For Rust or DWARF-based versioning, layer gendwarfksyms.config
# on top (requires gdb.config for DEBUG_INFO).
# See: kernel/module/Kconfig
CONFIG_MODVERSIONS=y
CONFIG_GENKSYMS=y
CONFIG_BASIC_MODVERSIONS=y
