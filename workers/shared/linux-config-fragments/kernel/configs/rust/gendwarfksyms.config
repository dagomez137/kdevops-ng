# Help: DWARF-based module versioning
#
# Replaces genksyms with gendwarfksyms for symbol version calculation
# from DWARF debug info. Required for Rust module support.
# Self-contained: inlines modversions.config's MODVERSIONS so it
# composes on the base alone. This fragment deliberately keeps
# GENKSYMS=n, replacing the genksyms backend with gendwarfksyms.
# See: kernel/module/Kconfig

#
# Inlined prerequisite (rust/modversions.config)
#
CONFIG_MODVERSIONS=y
CONFIG_BASIC_MODVERSIONS=y

CONFIG_GENKSYMS=n
CONFIG_GENDWARFKSYMS=y

# GENDWARFKSYMS depends on DEBUG_INFO and !DEBUG_INFO_REDUCED
# and !DEBUG_INFO_SPLIT.
CONFIG_DEBUG_INFO=y
CONFIG_DEBUG_INFO_DWARF_TOOLCHAIN_DEFAULT=y
CONFIG_DEBUG_INFO_REDUCED=n
CONFIG_DEBUG_INFO_SPLIT=n
