# Help: Preemption model and scheduler topology
#
# CONFIG_PREEMPT picks "Preemptible Kernel (Low-Latency Desktop)"
# from the Kconfig "Preemption Model" choice block. PREEMPT_DYNAMIC
# allows preempt=none|voluntary|full on the kernel command line at
# boot so the same kernel can serve different latency profiles.
#
# NO_HZ_IDLE keeps the tick running on busy CPUs but stops it on
# idle ones. NO_HZ_FULL (adaptive full tickless) would trade
# latency for throughput and is the alternative path.
#
# SCHED_SMT, SCHED_MC, SCHED_MC_PRIO, SCHED_CLUSTER let the
# scheduler understand the topology. SCHED_AUTOGROUP creates task
# groups per-session for fair CPU sharing.
#
# Every symbol is bool. No builtin/ counterpart needed. Note that
# CONFIG_PREEMPT in a choice block pulls PREEMPT_BUILD,
# PREEMPTION, PREEMPT_COUNT, PREEMPT_NOTIFIERS, and PREEMPT_RCU
# through Kconfig select; they are set explicitly here to keep
# merge_config -n from losing them between allnoconfig and
# olddefconfig.
# See: kernel/Kconfig.preempt
# See: init/Kconfig
# See: https://docs.kernel.org/locking/preempt-locking.html

#
# Preemption model
#
CONFIG_PREEMPT=y
CONFIG_PREEMPT_BUILD=y
CONFIG_PREEMPTION=y
CONFIG_PREEMPT_COUNT=y
CONFIG_PREEMPT_NOTIFIERS=y
CONFIG_PREEMPT_RCU=y
CONFIG_PREEMPT_DYNAMIC=y

#
# Tick management
#
CONFIG_NO_HZ_COMMON=y
CONFIG_NO_HZ_IDLE=y

#
# Scheduler topology and fairness
#
CONFIG_SCHED_SMT=y
CONFIG_SCHED_MC=y
CONFIG_SCHED_MC_PRIO=y
CONFIG_SCHED_CLUSTER=y
CONFIG_SCHED_AUTOGROUP=y
