# Help: CPU hardware-bug mitigations (x86)
#
# Every MITIGATION_* knob the x86 kernel exposes, set =y except
# MITIGATION_SLS which depends on CC_HAS_SLS (compiler support
# for -mharden-sls, not universally present).
#
# CPU_MITIGATIONS=y is the umbrella menuconfig; children are
# invisible until it is flipped on. Runtime policy can still
# disable individual mitigations via the "mitigations=" command
# line or per-flaw parameters (nopti, nospectre_v2, retbleed=off,
# etc.).
#
# Conditional mitigations that silently fall away when their
# build environment dep is not met:
# - MITIGATION_SLS: needs CC_HAS_SLS
# - MITIGATION_VMSCAPE: depends on KVM; layer virt/kvm.config first
#
# Newer kernels (>= 6.16) add MITIGATION_ITS, MITIGATION_TSA,
# MITIGATION_VMSCAPE; older kernels log a merge_config.sh WARNING
# for the unknown symbols and continue.
#
# Every symbol is bool. No builtin/ counterpart needed.
# See: arch/x86/Kconfig
# See: https://docs.kernel.org/admin-guide/hw-vuln/index.html
# See: https://docs.kernel.org/admin-guide/kernel-parameters.html
#   (search for "mitigations=")

CONFIG_CPU_MITIGATIONS=y
CONFIG_MITIGATION_PAGE_TABLE_ISOLATION=y
CONFIG_MITIGATION_RETPOLINE=y
CONFIG_MITIGATION_RETHUNK=y
CONFIG_MITIGATION_UNRET_ENTRY=y
CONFIG_MITIGATION_CALL_DEPTH_TRACKING=y
CONFIG_MITIGATION_IBPB_ENTRY=y
CONFIG_MITIGATION_IBRS_ENTRY=y
CONFIG_MITIGATION_SRSO=y
CONFIG_MITIGATION_SLS=n
CONFIG_MITIGATION_GDS=y
CONFIG_MITIGATION_RFDS=y
CONFIG_MITIGATION_SPECTRE_BHI=y
CONFIG_MITIGATION_MDS=y
CONFIG_MITIGATION_TAA=y
CONFIG_MITIGATION_MMIO_STALE_DATA=y
CONFIG_MITIGATION_L1TF=y
CONFIG_MITIGATION_RETBLEED=y
CONFIG_MITIGATION_SPECTRE_V1=y
CONFIG_MITIGATION_SPECTRE_V2=y
CONFIG_MITIGATION_SRBDS=y
CONFIG_MITIGATION_SSB=y

#
# Added in mainline >= 6.16
#
CONFIG_MITIGATION_ITS=y
CONFIG_MITIGATION_TSA=y
CONFIG_MITIGATION_VMSCAPE=y
