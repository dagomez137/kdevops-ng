# Help: Kernel version string with git commit SHA
# Kernel version string: replace "+" with git commit SHA.
#
# Without LOCALVERSION_AUTO, scripts/setlocalversion uses --short mode
# which prints "+" when past a tagged commit. With LOCALVERSION_AUTO=y,
# the full git describe is appended: -<count>-g<12-hex-sha>.
# Example: 6.18.0-12692-gcb015814f8b6 instead of 6.18.0+
#
# LOCALVERSION_AUTO depends on !COMPILE_TEST in init/Kconfig, so
# COMPILE_TEST must be disabled for this to take effect.
CONFIG_COMPILE_TEST=n
CONFIG_LOCALVERSION_AUTO=y
