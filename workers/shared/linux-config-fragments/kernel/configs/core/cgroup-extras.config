# Help: Additional cgroup controllers beyond the systemd baseline
#
# Layered on top of core/systemd.config, which already sets
# CGROUPS, CGROUP_SCHED, FAIR_GROUP_SCHED, CFS_BANDWIDTH, and
# MEMCG (the ones systemd itself requires). This fragment adds the
# controllers used by container runtimes, systemd-oomd, Docker,
# kubelet, and fine-grained resource control: device (v1 legacy),
# freezer, PIDs limit, hugetlb pages, perf-event attachment,
# network classid and priority, RDMA, device-memory (DMEM), the
# generic misc controller, and the block-cgroup IO latency, cost,
# and priority knobs.
#
# Every symbol is bool, so no builtin/ counterpart is needed.
# See: init/Kconfig
# See: net/Kconfig
# See: block/Kconfig
# See: https://docs.kernel.org/admin-guide/cgroup-v2.html

#
# Core controllers (init/Kconfig)
#
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_HUGETLB=y
CONFIG_CGROUP_PERF=y
CONFIG_CGROUP_RDMA=y
CONFIG_CGROUP_DMEM=y
CONFIG_CGROUP_MISC=y

#
# Network controllers (net/Kconfig)
#
CONFIG_CGROUP_NET_PRIO=y
CONFIG_CGROUP_NET_CLASSID=y

#
# Block IO controllers (block/Kconfig)
#
CONFIG_BLK_CGROUP=y
CONFIG_BLK_CGROUP_IOLATENCY=y
CONFIG_BLK_CGROUP_IOCOST=y
CONFIG_BLK_CGROUP_IOPRIO=y
