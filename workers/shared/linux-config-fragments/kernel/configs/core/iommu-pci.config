# Help: IOMMU and advanced PCI features
#
# IOMMU support for x86 (AMD_IOMMU, INTEL_IOMMU) plus the generic
# IOMMU API, IOMMU_DMA, IOMMU_SVA (shared virtual addressing for
# PASID-capable devices), and IOMMU_IOPF (I/O page fault). The
# INTEL_IOMMU_SVM path is needed for Intel SVM (Shared Virtual
# Memory) workloads. INTEL_IOMMU_PERF_EVENTS wires perf counters
# for IOTLB behaviour.
#
# PCI extras: ATS (Address Translation Services) and PASID /PRI
# for device-side virtual addressing, IOV for SR-IOV virtual
# functions, MMCONFIG for extended PCI configuration space, DOE
# (Data Object Exchange) for CMA/CXL device attestation,
# PCIEPORTBUS for PCIe port services, AUXILIARY_BUS for kernel
# "secondary" devices attached to a parent driver.
#
# HOTPLUG_PCI enables runtime PCI slot hotplug; ACPI, PCIe, SHPC,
# and CPCI transports cover the main server hardware backends.
#
# Every symbol is bool. No builtin/ counterpart needed.
# See: drivers/iommu/Kconfig
# See: drivers/pci/Kconfig
# See: drivers/pci/hotplug/Kconfig
# See: https://docs.kernel.org/core-api/genericirq.html
# See: https://docs.kernel.org/driver-api/iommu.html

#
# IOMMU
#
CONFIG_IOMMU_API=y
CONFIG_IOMMU_SUPPORT=y
CONFIG_IOMMU_DMA=y
CONFIG_IOMMU_SVA=y
CONFIG_IOMMU_IOPF=y
CONFIG_IOMMU_IOVA=y
CONFIG_IOMMU_IO_PGTABLE=y
CONFIG_IOMMU_MM_DATA=y
CONFIG_IOMMU_HELPER=y
CONFIG_IOMMU_DEFAULT_DMA_LAZY=y
CONFIG_AMD_IOMMU=y
CONFIG_INTEL_IOMMU=y
CONFIG_INTEL_IOMMU_SVM=y
CONFIG_INTEL_IOMMU_PERF_EVENTS=y
CONFIG_INTEL_IOMMU_FLOPPY_WA=y

#
# PCI advanced features
#
CONFIG_PCIEPORTBUS=y
CONFIG_PCI_MMCONFIG=y
CONFIG_PCI_ATS=y
CONFIG_PCI_PASID=y
CONFIG_PCI_PRI=y
CONFIG_PCI_IOV=y
CONFIG_PCI_DOE=y
CONFIG_AUXILIARY_BUS=y

#
# PCI hotplug
#
CONFIG_HOTPLUG_PCI=y
CONFIG_HOTPLUG_PCI_ACPI=y
CONFIG_HOTPLUG_PCI_PCIE=y
CONFIG_HOTPLUG_PCI_SHPC=y
CONFIG_HOTPLUG_PCI_CPCI=y
