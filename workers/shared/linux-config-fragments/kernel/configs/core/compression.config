# Help: Kernel and initramfs decompression support
#
# KERNEL_XZ selects XZ as the compression format for the kernel
# image itself (the build system compresses vmlinux into
# vmlinuz.xz). This is one entry in a Kconfig choice block;
# alternatives are KERNEL_GZIP, KERNEL_BZIP2, KERNEL_LZMA,
# KERNEL_LZO, KERNEL_LZ4, KERNEL_ZSTD.
#
# RD_* flags tell the kernel to accept the matching initramfs
# compression format at boot; enabling all seven means any
# initramfs generator (dracut, mkinitcpio, mkosi, initramfs-tools)
# is supported regardless of which codec it emits.
#
# XZ_DEC and its BCJ / x86 / ARM64 / RISCV filters provide XZ
# decompression support throughout the kernel (used by
# ZSTD-packaged modules, squashfs, erofs, firmware files).
# ZLIB_{DEFLATE,INFLATE} and ZSTD_{COMPRESS,DECOMPRESS,COMMON}
# are utility libraries consumed by many subsystems.
#
# 842_COMPRESS / 842_DECOMPRESS and CRYPTO_842 enable the IBM
# Power8 NX hardware-assisted compression algorithm exposed
# through the crypto API. LZ4HC is the high-compression LZ4
# variant.
# See: init/Kconfig (Kernel compression mode choice)
# See: lib/xz/Kconfig
# See: lib/zstd/Kconfig

#
# Kernel image compression format
#
CONFIG_KERNEL_XZ=y

#
# Initramfs decompression support
#
CONFIG_RD_GZIP=y
CONFIG_RD_BZIP2=y
CONFIG_RD_LZMA=y
CONFIG_RD_XZ=y
CONFIG_RD_LZO=y
CONFIG_RD_LZ4=y
CONFIG_RD_ZSTD=y

#
# XZ helpers
#
CONFIG_XZ_DEC=y
CONFIG_XZ_DEC_BCJ=y
CONFIG_XZ_DEC_X86=y
CONFIG_XZ_DEC_ARM64=y
CONFIG_XZ_DEC_RISCV=y

#
# Library codecs
#
# ZLIB_DEFLATE, ZLIB_INFLATE, ZSTD_COMMON, ZSTD_COMPRESS, and
# ZSTD_DECOMPRESS are tristate with no user prompt; they are
# selected by consumers (CRYPTO_DEFLATE / CRYPTO_ZSTD,
# BTRFS_FS_COMPRESS_*, SQUASHFS_*, etc.) so a direct =y write
# here would be overwritten. Users who want them promoted pull
# in the matching consumer or set them ad-hoc.
#
CONFIG_LZ4HC_COMPRESS=m

#
# 842 (IBM Power NX hardware-assisted compression)
#
CONFIG_842_COMPRESS=m
CONFIG_842_DECOMPRESS=m
CONFIG_CRYPTO_842=m
