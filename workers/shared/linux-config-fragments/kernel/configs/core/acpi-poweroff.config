# Help: ACPI power button for QMP graceful shutdown
#
# ACPI_TINY_POWER_BUTTON signals init directly (SIGRTMIN+4 = poweroff)
# for cloud/VM environments. No input layer or userspace daemon needed.
# Mutually exclusive with ACPI_BUTTON (depends on !ACPI_BUTTON).
#
# Must be =y (built-in). QEMU checks PM1_EN power button enable bit
# in acpi_pm1_evt_power_down(). If the bit is 0 (no driver loaded),
# the event is silently dropped, not queued. With =y, the driver
# initializes at device_initcall before any userspace (including the
# initrd init process), so power button events work from the start.
CONFIG_ACPI_BUTTON=n
CONFIG_ACPI_TINY_POWER_BUTTON=y
