# Help: Core kernel features for a usable QEMU guest
#
# Architecture-generic: works for both x86_64 and arm64.

# General setup (init/Kconfig)
CONFIG_SMP=y
CONFIG_BUG=y
CONFIG_EXPERT=y
CONFIG_SYSVIPC=y
CONFIG_POSIX_TIMERS=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_FUTEX=y
CONFIG_AIO=y
CONFIG_IO_URING=y
CONFIG_ADVISE_SYSCALLS=y
CONFIG_MEMBARRIER=y
CONFIG_MULTIUSER=y
CONFIG_CHECKPOINT_RESTORE=y
CONFIG_CROSS_MEMORY_ATTACH=y
CONFIG_CPU_ISOLATION=y
CONFIG_HOTPLUG_CPU=y
CONFIG_PRINTK=y
CONFIG_ELF_CORE=y
CONFIG_KALLSYMS=y

# Block layer (block/Kconfig)
CONFIG_BLOCK=y

# Block devices (drivers/block/Kconfig)
CONFIG_BLK_DEV=y

# Memory management (mm/Kconfig)
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_CMA=y
CONFIG_CMA_SYSFS=y
CONFIG_ZONE_DMA=y
CONFIG_HUGETLBFS=y
CONFIG_SHMEM=y

# Executable formats (fs/Kconfig.binfmt)
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_MISC=y
CONFIG_BINFMT_SCRIPT=y
CONFIG_COREDUMP=y

# File systems, VFS infrastructure (fs/Kconfig, fs/*/Kconfig)
CONFIG_DEVTMPFS=y
CONFIG_PROC_FS=y
CONFIG_PROC_PAGE_MONITOR=y
CONFIG_PROC_SYSCTL=y
CONFIG_SYSFS=y
CONFIG_FILE_LOCKING=y
CONFIG_QUOTA=y
CONFIG_CONFIGFS_FS=m
CONFIG_NETWORK_FILESYSTEMS=y

# Character devices (drivers/tty/Kconfig, drivers/char/Kconfig)
CONFIG_TTY=y
CONFIG_VT=y
CONFIG_UNIX98_PTYS=y
CONFIG_DEVMEM=y
CONFIG_HW_RANDOM=y

# Input devices (drivers/input/Kconfig)
CONFIG_INPUT=y

# PCI (drivers/pci/Kconfig)
CONFIG_PCI=y
CONFIG_PCI_MSI=y

# Device drivers (drivers/base/Kconfig, drivers/*/Kconfig)
CONFIG_ACPI=y
CONFIG_IOMMU_SUPPORT=y
CONFIG_FW_LOADER=y
CONFIG_HWMON=y
CONFIG_USB_SUPPORT=y
CONFIG_ALLOW_DEV_COREDUMP=y

# Virtio drivers (drivers/virtio/Kconfig, drivers/block/Kconfig)
CONFIG_VIRTIO_MENU=y
CONFIG_VIRTIO_PCI=m
CONFIG_VIRTIO_BLK=m
CONFIG_VIRTIO_CONSOLE=m

# Networking support (net/Kconfig, net/ipv4/Kconfig)
CONFIG_NET=y
CONFIG_UNIX=y
CONFIG_NET_CORE=y
CONFIG_NETDEVICES=y
CONFIG_INET=y
CONFIG_IP_PNP=y
CONFIG_IP_PNP_DHCP=y
CONFIG_NETFILTER=y
CONFIG_PACKET=m
CONFIG_SYN_COOKIES=y
CONFIG_UNIX_DIAG=y

# Kernel hacking (lib/Kconfig.debug)
CONFIG_DEBUG_KERNEL=y
CONFIG_PRINTK_TIME=y
CONFIG_MAGIC_SYSRQ=y
CONFIG_DEBUG_MISC=y
CONFIG_DEBUG_FS=y

# VFS notify, Unicode casefolding, and /proc/pid/mem
CONFIG_FANOTIFY=y
CONFIG_FANOTIFY_ACCESS_PERMISSIONS=y
CONFIG_UNICODE=y
CONFIG_PROC_MEM_ALWAYS_FORCE=y
