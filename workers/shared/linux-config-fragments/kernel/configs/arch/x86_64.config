# Help: x86_64-specific QEMU guest configs
#
# arch/x86/Kconfig options for KVM guest support and serial console.

# KVM guest support (arch/x86/Kconfig)
CONFIG_HYPERVISOR_GUEST=y
CONFIG_PARAVIRT=y
CONFIG_KVM_GUEST=y

# Serial console (console=ttyS0,115200 on x86 QEMU)
# SERIAL_8250 is in drivers/tty/serial/8250/Kconfig (generic)
# but is the standard x86 QEMU serial device.
# SERIAL_8250_CONSOLE depends on SERIAL_8250=y (not =m).
# Serial console requires the driver built-in.
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
