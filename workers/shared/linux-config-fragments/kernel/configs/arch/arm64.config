# Help: ARM64-specific QEMU virt machine configs
#
# The arm64 virt machine uses PL011 for serial and supports
# both VIRTIO_MMIO and VIRTIO_PCI for virtio transport.

# PL011 serial console (console=ttyAMA0 on arm64 QEMU virt)
# SERIAL_AMBA_PL011_CONSOLE depends on SERIAL_AMBA_PL011=y (not =m).
# Serial console requires the driver built-in.
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y
CONFIG_CONSOLE_TRANSLATIONS=y

# ARM timer
CONFIG_ARM_ARCH_TIMER_EVTSTREAM=y

# Memory-mapped virtio transport
CONFIG_VIRTIO_MMIO=m

# SMMUv3 IOMMU: the arm64 vIOMMU (QEMU virt -device arm-smmuv3); the
# arm64 driver for VFIO/userspace drivers, paired with core/vfio.config.
CONFIG_ARM_SMMU_V3=m
