# Help: Built-in overrides for software RAID (MD)
#
# Promotes the MD driver to =y and adds MD_AUTODETECT so that
# on-disk md-superblock arrays are assembled during kernel boot
# without relying on userspace mdadm.
CONFIG_BLK_DEV_MD=y
CONFIG_MD_AUTODETECT=y
CONFIG_MD_LINEAR=y
CONFIG_MD_RAID0=y
CONFIG_MD_RAID1=y
CONFIG_MD_RAID10=y
CONFIG_MD_RAID456=y
