# Help: Built-in overrides for nftables
#
# Promotes the nftables core and the common NAT/CT/compat
# expressions to =y for no-modprobe boot scenarios.
#
# NFT_REJECT, NFT_REJECT_INET, NFT_FIB, and NFT_FIB_INET are left at
# =m here. Their IPv6 counterparts (NFT_REJECT_IPV6, NFT_FIB_IPV6)
# depend on IPV6, which became a bool (default y) in 7.1 and is set
# =y by core/systemd.config, so the inet-family members can reach =y
# on a compose that includes systemd.config. This builtin does not
# force IPV6 on its own; promote them with an ad-hoc override (or use
# the no-modules path, where MODULES=n promotes every =m to =y).
CONFIG_NF_TABLES=y
CONFIG_NFT_CT=y
CONFIG_NFT_MASQ=y
CONFIG_NFT_REDIR=y
CONFIG_NFT_NAT=y
CONFIG_NFT_COMPAT=y
CONFIG_NFT_HASH=y
CONFIG_NFT_LIMIT=y
CONFIG_NFT_LOG=y
CONFIG_NF_FLOW_TABLE=y
