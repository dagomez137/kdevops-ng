# Help: Built-in overrides for netfilter NAT and iptables
#
# Promotes the core conntrack, NAT, xtables, and IPv4 iptables
# tables to =y for no-modprobe boot scenarios such as a VM that
# needs the firewall/NAT stack ready before userspace.
#
# IPv6 iptables (IP6_NF_*) are left at =m here. They depend on
# INET && IPV6; IPV6 became a bool (default y) in 7.1 and
# core/systemd.config sets it =y, so IP6_NF_*=y is reachable on any
# compose that includes systemd.config. This builtin does not force
# IPV6 on its own, so promote IP6_NF_*=y with an ad-hoc override (or
# use the no-modules path, where MODULES=n promotes every =m to =y).
CONFIG_NF_CONNTRACK=y
CONFIG_NF_NAT=y
CONFIG_NETFILTER_XTABLES=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_IPTABLES_LEGACY=y
CONFIG_IP_NF_FILTER=y
CONFIG_IP_NF_MANGLE=y
CONFIG_IP_NF_NAT=y
CONFIG_IP_NF_TARGET_MASQUERADE=y
CONFIG_IP_NF_RAW=y
