# Help: F2FS (Flash-Friendly File System)
#
# F2FS_FS=m with extended attributes (F2FS_FS_XATTR), POSIX ACL
# (F2FS_FS_POSIX_ACL), stat and iostat accounting, fault
# injection used by xfstests fault scenarios, and
# F2FS_UNFAIR_RWSEM which biases the filesystem rwsem toward
# writers for throughput under heavy write workloads.
#
# F2FS is log-structured and tailored for flash media; in a VM
# guest it is useful for filesystem-agnostic testing that covers
# fscrypt/fsverity plus the log-structured path that ext4 and
# btrfs do not exercise.
#
# Prerequisites inlined per the self-containment rule:
# - BLK_CGROUP=y   gates F2FS_UNFAIR_RWSEM (F2FS's block cgroup
#                  priority-aware rwsem biasing). Also set by
#                  core/cgroup-extras.config.
#
# Every symbol is bool except F2FS_FS itself (tristate). No
# builtin/ counterpart is needed; layer an explicit
# CONFIG_F2FS_FS=y override if you want it compiled in.
# See: fs/f2fs/Kconfig
# See: https://docs.kernel.org/filesystems/f2fs.html

CONFIG_BLK_CGROUP=y
CONFIG_F2FS_FS=m
CONFIG_F2FS_FS_XATTR=y
CONFIG_F2FS_FS_POSIX_ACL=y
CONFIG_F2FS_STAT_FS=y
CONFIG_F2FS_IOSTAT=y
CONFIG_F2FS_FAULT_INJECTION=y
CONFIG_F2FS_UNFAIR_RWSEM=y
