# Help: Cryptographic API core framework
#
# Enables the cryptographic API core and its main transformation
# types. Most tristates default to =m; layer
# builtin/security/crypto-core.config for a built-in (=y) kernel.
#
# The crypto/Kconfig file structures the API into type families:
# ALGAPI (algorithm registration), AEAD (authenticated encryption
# with associated data), HASH, SKCIPHER (symmetric ciphers), KPP
# (key-pair protocols), AKCIPHER (asymmetric ciphers), SIG
# (signatures). Each family symbol is selected by the concrete
# algorithms under it, so setting them =m here is what makes the
# framework loadable as modules.
#
# CRYPTO_USER_API_* exposes the af_alg userspace interface used
# by libraries like libkcapi and cryptsetup's --key-size-as-hash.
# CRYPTO_SELFTESTS is bool and depends on EXPERT=y (set by
# core/core.config), so it can be flipped on by layering a small
# override when users want to run the boot-time self-tests.
#
# The generic compressors for crypto (DEFLATE/LZO/LZ4/ZSTD) are
# included so that IPComp, IPSec payload compression, and
# filesystem-level transparent compression (e.g. dm-compress) have
# a registered provider available.
#
# Specific algorithm choices (AES, SHA, GCM, etc.) live in
# security/crypto-algorithms.config, which is the natural
# companion fragment. Picking crypto-core alone gives you the
# framework and nothing else to test against.
# See: crypto/Kconfig
# See: include/crypto/algapi.h
# See: https://docs.kernel.org/crypto/index.html

#
# Core framework
#
CONFIG_CRYPTO=m
CONFIG_CRYPTO_ALGAPI=m
CONFIG_CRYPTO_AEAD=m
CONFIG_CRYPTO_HASH=m
CONFIG_CRYPTO_SKCIPHER=m
CONFIG_CRYPTO_KPP=m
CONFIG_CRYPTO_AKCIPHER=m
CONFIG_CRYPTO_SIG=m
CONFIG_CRYPTO_MANAGER=m

#
# Utility transforms
#
CONFIG_CRYPTO_NULL=m
CONFIG_CRYPTO_PCRYPT=m
CONFIG_CRYPTO_CRYPTD=m
CONFIG_CRYPTO_AUTHENC=m

#
# Userspace af_alg interface
#
CONFIG_CRYPTO_USER=m
CONFIG_CRYPTO_USER_API_HASH=m
CONFIG_CRYPTO_USER_API_SKCIPHER=m
CONFIG_CRYPTO_USER_API_RNG=m
CONFIG_CRYPTO_USER_API_AEAD=m

#
# Generic compressors (IPComp, filesystem transparent compression)
#
CONFIG_CRYPTO_DEFLATE=m
CONFIG_CRYPTO_LZO=m
CONFIG_CRYPTO_LZ4=m
CONFIG_CRYPTO_ZSTD=m
