# Help: Linux Security Modules (major LSMs)
#
# Enables the five major mainline LSMs plus Landlock and Lockdown:
# AppArmor, SELinux, Smack, TOMOYO, Yama, Landlock, and
# LOCKDOWN_LSM. All six are bool and depend on CONFIG_SECURITY,
# so they can coexist in a single kernel image. At boot time the
# active set is chosen via the "lsm=" kernel command-line
# parameter (or CONFIG_LSM default); the "lsm=" list is processed
# in order and enables each named LSM.
#
# Prerequisites are inlined so the fragment composes standalone:
# - SECURITY=y       parent symbol for every LSM. Already set by
#                    security/security.config; written again here
#                    so this fragment works on its own.
# - AUDIT=y          required by SELinux and selected by
#                    AppArmor. Overrides the AUDIT=n default in
#                    core/systemd.config; this is deliberate,
#                    the user picked a fragment that turns on
#                    LSMs that depend on audit.
#
# SECURITY_LOCKDOWN_LSM selects MODULE_SIG when MODULES=y. With
# core/modules.config's MODULE_SIG=n, Kconfig promotes MODULE_SIG
# to =y via the select chain. The kernel still boots without a
# signing key if MODULE_SIG_ALL / MODULE_SIG_FORCE are left off.
#
# SECURITY_APPARMOR_EXPORT_BINARY is enabled so the userspace
# apparmor_parser can load pre-compiled policy caches.
# SECURITY_APPARMOR_HASH is enabled so sha256 digests of loaded
# policies are exposed in /sys/kernel/security/apparmor/.
# See: security/Kconfig
# See: security/apparmor/Kconfig
# See: security/selinux/Kconfig
# See: security/smack/Kconfig
# See: security/tomoyo/Kconfig
# See: security/yama/Kconfig
# See: security/landlock/Kconfig
# See: security/lockdown/Kconfig
# See: https://docs.kernel.org/admin-guide/LSM/index.html

#
# Inlined prerequisites
#
CONFIG_SECURITY=y
CONFIG_AUDIT=y

#
# AppArmor
#
CONFIG_SECURITY_APPARMOR=y
CONFIG_SECURITY_APPARMOR_INTROSPECT_POLICY=y
CONFIG_SECURITY_APPARMOR_HASH=y
CONFIG_SECURITY_APPARMOR_HASH_DEFAULT=y
CONFIG_SECURITY_APPARMOR_EXPORT_BINARY=y

#
# SELinux
#
CONFIG_SECURITY_SELINUX=y
CONFIG_SECURITY_SELINUX_BOOTPARAM=y
CONFIG_SECURITY_SELINUX_DEVELOP=y

#
# Smack
#
CONFIG_SECURITY_SMACK=y
CONFIG_SECURITY_SMACK_NETFILTER=y
CONFIG_SECURITY_SMACK_APPEND_SIGNALS=y

#
# TOMOYO
#
CONFIG_SECURITY_TOMOYO=y

#
# Yama (ptrace scope)
#
CONFIG_SECURITY_YAMA=y

#
# Landlock (unprivileged sandboxing)
#
CONFIG_SECURITY_LANDLOCK=y

#
# Lockdown (integrity vs confidentiality modes)
#
CONFIG_SECURITY_LOCKDOWN_LSM=y
CONFIG_SECURITY_LOCKDOWN_LSM_EARLY=y
