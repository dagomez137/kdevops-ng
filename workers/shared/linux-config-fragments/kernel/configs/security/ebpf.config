# Help: eBPF stack for tracing, observability, and networking
#
# Comprehensive BPF configuration for bcc, bpftrace, libbpf,
# and systemd resource control. Includes error injection for
# BPF kprobe override testing.
# See: https://docs.kernel.org/bpf/
# See: https://github.com/libbpf/libbpf
# See: https://github.com/iovisor/bcc/blob/master/docs/kernel_config.md

#
# Core BPF
#
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_JIT_ALWAYS_ON=y
CONFIG_BPF_STREAM_PARSER=y
CONFIG_BPF_EVENTS=y
CONFIG_CGROUP_BPF=y

# BPF LSM (depends on SECURITY)
CONFIG_SECURITY=y
CONFIG_BPF_LSM=y

# BTF type information (depends on DEBUG_INFO)
CONFIG_DEBUG_INFO=y
CONFIG_DEBUG_INFO_DWARF_TOOLCHAIN_DEFAULT=y
CONFIG_DEBUG_INFO_REDUCED=n
CONFIG_DEBUG_INFO_BTF=y
CONFIG_IKHEADERS=y

#
# Tracing infrastructure
#
CONFIG_PERF_EVENTS=y
CONFIG_PROFILING=y
CONFIG_FTRACE=y
CONFIG_DYNAMIC_FTRACE=y
CONFIG_FTRACE_SYSCALLS=y
CONFIG_FUNCTION_TRACER=y
CONFIG_FUNCTION_GRAPH_TRACER=y
CONFIG_STACK_TRACER=y
CONFIG_KPROBES=y
CONFIG_KPROBE_EVENTS=y
CONFIG_UPROBE_EVENTS=y

#
# BPF networking
#
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NETFILTER_XTABLES=y
CONFIG_NETFILTER_XT_MATCH_BPF=y
CONFIG_NET_SCHED=y
CONFIG_NET_SCH_SFQ=y
CONFIG_NET_CLS_ACT=y
CONFIG_NET_CLS_BPF=y
CONFIG_NET_ACT_BPF=y
CONFIG_NET_ACT_GACT=y
CONFIG_NET_ACT_POLICE=y
CONFIG_LWTUNNEL_BPF=y
CONFIG_IPV6_SEG6_LWTUNNEL=y
CONFIG_VXLAN=y
CONFIG_DUMMY=y

#
# BPF IR/LIRC
#
CONFIG_RC_CORE=y
CONFIG_LIRC=y
CONFIG_BPF_LIRC_MODE2=y

#
# Error injection (kprobe override testing)
#
CONFIG_BPF_KPROBE_OVERRIDE=y
CONFIG_FUNCTION_ERROR_INJECTION=y
