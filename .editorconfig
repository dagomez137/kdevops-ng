root = true

[*]
charset = utf-8
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true

[*.{sh,bash}]
indent_style = tab
tab_width = 4

[*.{c,h}]
indent_style = tab
tab_width = 8

[*.py]
indent_style = space
indent_size = 4

[*.rs]
indent_style = space
indent_size = 4
max_line_length = 100

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
max_line_length = 80
